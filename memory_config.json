{
  "memvid_path": "/a0/usr/memory/fused/memory.mv2",
  "simplemem_path": "/a0/usr/memory/fused/memory.lancedb",
  "kg_path": "/a0/usr/memory/fused/knowledge_graph.json",
  "embedding_model": "text-embedding-3-small",
  "local_embedding_model": "all-MiniLM-L6-v2",
  "enable_memvid": true,
  "enable_simplemem": true,
  "enable_kg": true,
  "enable_compression": true,
  "rrf_k": 60,
  "default_k": 10,
  "retrieval_weights": {
    "semantic": 0.5,
    "lexical": 0.3,
    "kg": 0.2
  },
  "decay_threshold_days": 30,
  "merge_similarity_threshold": 0.85,
  "nvidia_roles": {
    "chat":      { "model": "qwen/qwen3.5-397b-a17b",                 "api_key_env": "NVIDIA_API_KEY_CHAT" },
    "utility":   { "model": "minimaxai/minimax-m2.1",                 "api_key_env": "NVIDIA_API_KEY_UTILITY" },
    "browser":   { "model": "moonshotai/kimi-k2.5",                   "api_key_env": "NVIDIA_API_KEY_BROWSER" },
    "code":      { "model": "mistralai/devstral-2-123b-instruct-2512","api_key_env": "NVIDIA_API_KEY_CODE" },
    "reasoning": { "model": "z-ai/glm5",                              "api_key_env": "NVIDIA_API_KEY_REASONING" },
    "fast":      { "model": "stepfun-ai/step-3.5-flash",              "api_key_env": "NVIDIA_API_KEY_FAST" },
    "embedding": { "model": "nvidia/nv-embed-v2",                     "api_key_env": "NVIDIA_API_KEY_EMBEDDING" }
  }
}
